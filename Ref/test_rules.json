{
  "defaults": {
    "failMessage": "⚠️ Проверка не пройдена"
  },
  "rules": [
    {
      "name": "Проверка: Достаточно ли бумаги",
      "description": "Проверяет, что на складе есть бумага",
      "conditions": [
        {
          "source": "orders",
          "checkAll": true,
          "operator": "calc",
          "formula": "stock >= req",
          "expectedOperator": "eq",
          "expected": "1",
          "failMessage": "❌ НЕ ХВАТАЕТ БУМАГИ!"
        }
      ]
    },
    {
      "name": "Проверка: Специальный заказчик",
      "description": "Блокирует, если в имени заказчика есть 'ЛИНК'",
      "conditions": [
        {
          "field": "client",
          "operator": "contains",
          "value": "ЛИНК",
          "caseSensitive": false,
          "failMessage": "⚠️ Заказчик содержит 'ЛИНК' — требуется согласование!"
        }
      ]
    }
  ]
}