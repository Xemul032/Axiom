{
  "defaults": {
    "failMessage": "⚠️ Проверка не пройдена"
  },
  "rules": [
    {
      "name": "Мги + проверка",
      "logic": "AND",
      "conditions": [
        {
          "field": "orders",
          "operator": "ordersContain",
          "value": "МГИ",
          "subField": "localPP",
          "caseSensitive": false
        },
        {
          "field": "design",
          "operator": "contains",
          "value": "MGI",
          "caseSensitive": false
        }
      ],
      "failMessage": "Запуск заказа без проверки на соответствие требованиям МГИ невозможен!"
    },
    {
      "name": "Масса заказа",
      "logic": "AND",
      "conditions": [
        {
          "field": "mass",
          "operator": "gte",
          "value": "200",
          "caseSensitive": false
        },
        {
          "field": "globalPP",
          "operator": "notContains",
          "value": "грузовым",
          "caseSensitive": false
        },
        {
          "field": "deliveryPoint",
          "operator": "contains",
          "value": "ТАСМА",
          "caseSensitive": false
        },
        {
          "field": "address",
          "operator": "notContains",
          "value": "самовывоз",
          "caseSensitive": false
        }
      ],
      "failMessage": "Заказ слишком тяжёлый! Не забудьте добавить платную доставку!"
    }
  ]
}